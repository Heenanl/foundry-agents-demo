# ─────────────────────────────────────────────────────────────
# Azure AI Foundry — required
# ─────────────────────────────────────────────────────────────
# From `azd up` outputs (deployment/README.md)
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<project-name>

# Model deployment (created by deployment/resources.bicep, default gpt-4o-mini)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# Foundry agent names — optional overrides
# Defaults match the agents you create in the Foundry portal.
# ─────────────────────────────────────────────────────────────
AZURE_AI_AGENT_ORCHESTRATOR=rfp-orchestrator-agent
AZURE_AI_AGENT_SUMMARY=rfp-summary-agent
AZURE_AI_AGENT_RISK=rfp-risk-agent
AZURE_AI_AGENT_COMPLIANCE=rfp-compliance-agent

# ─────────────────────────────────────────────────────────────
# Azure resources — informational, also produced by `azd up`
# ─────────────────────────────────────────────────────────────
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_NAME=
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_NAME=
AZURE_STORAGE_NAME=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
